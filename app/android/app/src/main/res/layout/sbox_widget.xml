<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sbox_widget_bg"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/sbox_dot"
            android:contentDescription="estado" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="SBOX"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            android:letterSpacing="0.25"
            android:fontFamily="monospace" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Desconectado"
        android:textColor="#8A8F98"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_last"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:text="Sin contenido todavía"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:maxLines="4"
        android:ellipsize="end"
        android:gravity="top" />
</LinearLayout>
